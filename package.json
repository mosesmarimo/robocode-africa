{
  "name": "robocode-africa",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel --stream dev",
    "dev:backend": "pnpm --filter robocode-backend dev",
    "dev:frontend": "pnpm --filter robocode-frontend dev",
    "build": "pnpm --filter robocode-backend build && pnpm --filter robocode-frontend build",
    "typecheck": "pnpm -r typecheck",
    "db:push": "pnpm --filter robocode-backend db:push",
    "db:seed": "pnpm --filter robocode-backend db:seed",
    "db:reset": "pnpm --filter robocode-backend db:reset"
  }
}
