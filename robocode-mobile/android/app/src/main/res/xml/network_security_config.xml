<?xml version="1.0" encoding="utf-8"?>
<!--
  Production talks to the backend over HTTPS (api.robocode.africa). Cleartext is
  permitted ONLY for local development hosts so the app can reach a dev backend:
    - 10.0.2.2  : the host machine as seen from the Android emulator
    - localhost / 127.0.0.1
  Override the API base at run time with --dart-define=API_BASE=...
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
    </domain-config>
    <base-config cleartextTrafficPermitted="false" />
</network-security-config>
